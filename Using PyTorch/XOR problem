       [1.],\n","        [0.]])\n"]}],"source":["# Import required libraries\n","\n","import torch as t\n","import torch.nn as nn\n","\n","## XOR dataset\n","# input data\n","\n","I = t.tensor([\n","    [0., 0.],\n","    [0., 1.],\n","    [1., 0.],\n","    [1., 1.]\n","], dtype=t.float32)\n","\n","# output data\n","\n","Y = t.tensor([\n","    [0.],\n","    [1.],\n","    [1.],\n","    [0.]\n","], dtype=t.float32)\n","\n","# Defining AI model class\n","\n","class MLP(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","\n","        self.layer1 = nn.Linear(2, 2)   # Hidden layer\n","        self.layer2 = nn.Linear(2, 1)   # Output layer\n","\n","        self.sigmoid = nn.Sigmoid()\n","\n","    def forward(self, x):\n","        x = self.sigmoid(self.layer1(x))      # layer 1 computation\n","        x = self.sigmoid(self.layer2(x))      # layer 2 computation\n","        return x\n","\n","# Create model\n","\n","model = MLP()\n","\n","# Loss function\n","\n","compute_loss = nn.BCELoss()     # binary cross entropy\n","\n","# Optimizer\n","\n","optimizer = t.optim.SGD(model.parameters(), lr=1.5)\n","\n","# Training loop\n","\n","epochs = 1000\n","\n","for epoch in range(epochs):\n","\n","    # Clear previous gradients\n","    optimizer.zero_grad()\n","\n","    # Forward propagation\n","    P = model(I)\n","\n","    # Compute loss\n","    loss = compute_loss(P, Y)\n","\n","    # Backpropagation\n","    loss.backward()\n","\n","    # Update weights and biases\n","    optimizer.step()\n","\n","    # Print progress\n","    if (epoch + 1) % 1000 == 0:\n","        print(f\"Epoch [{epoch + 1}/{epochs}], Loss: {loss.item():.6f}\")\n","\n","# Evaluation\n","\n","with t.no_grad():\n","    P = model(I)\n","    predictions = (P >= 0.5).float()\n","\n","print(\"\\nTarget:\\n\")\n","print(Y)\n","\n","print(\"\\nPredicted probabilities:\\n\")\n","print(P)\n","\n","print(\"\\nPredicted classes:\\n\")\n","print(predictions)"]},{"cell_type":"code","source":[],"metadata":{"id":"AKoumaanzr5L"},"execution_count":null,"outputs":[]}]}