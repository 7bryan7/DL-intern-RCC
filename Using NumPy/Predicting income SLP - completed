as):\n","\n","  # Calculate mse_loss\n","  mse_loss = np.mean((prediction_matrix - ground_truth)**2)\n","  print(f\"Mean Squared Error: {mse_loss:.4f}\")\n","\n","  # Calculate gradients\n","  m = input_matrix.shape[0] # Correct: use input_matrix argument\n","\n","  # Error gradient (derivative of MSE with respect to post_activation_matrix A)\n","  # dL/dA = 2/m * (A - Y)\n","  error_gradient = (2 / m) * (prediction_matrix - ground_truth) # Correct: use prediction_matrix and ground_truth arguments\n","\n","  # Weight gradient (derivative of MSE with respect to W)\n","  # dL/dW = X.T @ (dL/dA * dA/dZ * dZ/dW)\n","  # Since dA/dZ = 1 (linear activation) and dZ/dW = X.T\n","  # dL/dW = X.T @ error_gradient\n","  weight_gradient = np.dot(input_matrix.T, error_gradient) # Correct: use input_matrix argument\n","\n","  # Bias gradient (derivative of MSE with respect to b)\n","  # If b is a single scalar bias, its gradient is the sum of error_gradient\n","  bias_gradient = np.sum(error_gradient) # Correct: sum for scalar bias\n","\n","  # Update weights and bias\n","  new_weights = current_weight - learning_rate * weight_gradient\n","  new_bias = current_bias - learning_rate * bias_gradient\n","\n","  # Removed verbose prints for weights and bias update status\n","\n","  return new_weights, new_bias"],"metadata":{"id":"iI7zmGLbCvY8"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["> **Training the model for a number of epochs**"],"metadata":{"id":"_c8jnK8SJIsD"}},{"cell_type":"code","source":["print(\"\\nInput matrix:\\n\")\n","print(I)\n","\n","print(\"\\nGround Truth matrix:\\n\")\n","print(Y)\n","\n","for i in range(epoch):\n","  print(\"\\n=================================================================================\")\n","  print(f\"\\nEpoch {i+1}:\")\n","\n","  # Printing Input, weight, bias, ground truth matrices\n","\n","  print(\"\\nPrediction matrix:\\n\")\n","  print(P)\n","  print(\"\\nWeight matrix:\\n\")\n","  print(W)\n","  print(\