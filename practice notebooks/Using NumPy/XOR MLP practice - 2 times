matrix:\n","\n","[[0]\n"," [1]\n"," [1]\n"," [0]]\n","\n","Mean squared error: 0.17148902698788893\n","\n","Prediction matrix:\n","\n","[[0.0716831 ]\n"," [0.65919131]\n"," [0.65869915]\n"," [0.66946307]]\n","\n","Ground truth matrix:\n","\n","[[0]\n"," [1]\n"," [1]\n"," [0]]\n"]}],"source":["# =========================== importing required libraries\n","\n","import numpy as np\n","\n","# =========================== input matrix - I\n","\n","I = np.array([\n","    [0, 0],\n","    [0, 1],\n","    [1, 0],\n","    [1, 1]\n","])\n","\n","# ========================== output matrix - Y (ground truth matrix)\n","\n","Y = np.array([\n","    [0],\n","    [1],\n","    [1],\n","    [0]\n","])\n","\n","# ========================== defining hyper parameters\n","\n","epoch = 1200      # no of cycles\n","\n","lr = 1.5          # learning rate of model\n","\n","# ============================= initiating weights and bias (w1, b1, w2, b2) (for 2 layers)\n","\n","w1 = np.random.randn(2, 2)       # weight of layer 1\n","\n","b1 = np.random.randn(1, 2)       # bias of layer 1\n","\n","w2 = np.random.randn(2, 1)        # weight of layer 2\n","\n","b2 = np.random.randn(1, 1)       # bias of layer 2\n","\n","# ========================= user defined functions\n","\n","def sigmoid(x):\n","  return 1 / (1 + np.exp(-x))\n","\n","def sigmoid_derivative(x):\n","  return sigmoid(x) * (1 - sigmoid(x))\n","\n","def SLP(I, w, b):\n","  return(sigmoid(np.dot(I, w) + b))\n","\n","def back_prop(I, Y, P, A1, w1, w2, b1, b2, lr):     # =================== back propagation & error calculation\n","\n","  # calculating mse from output layer\n","\n","  mse = np.mean((P - Y) ** 2)\n","\n","  # calculating error gradients of layer 1 & layer 2\n","\n","  delta2 = (2 / I.shape[0]) * (P - Y) * sigmoid_derivative(np.dot(A1, w2) + b2)\n","\n","  delta1 = np.dot(delta2, w2.T) * sigmoid_derivative(np.dot(I, w1) + b1)\n","\n","  # calculating weight gradients of layer 1 & layer 2\n","\n","  dw2 = np.dot(A1.T, delta2)\n","  dw1 = np.dot(I.T, delta1)\n","\n","  # calculating bias gradients of layer 1 & layer 2\n","\n","  db2 = np.sum(delta2, axis=0)\n","  db1 = np.sum(delta1, axis=0)\n","\n","  # returning new weights, bias and mse\n","\n","  return (w1 - dw1), (b1 - db1), (w2 - dw2), (b2 - db2), mse\n","\n","# ======================= training the model\n","\n","for i in range(epoch):\n","  print(f\"\\nEpoch {i+1}:\\n\")\n","\n","  # layer 1 forward pass\n","\n","  A1 = SLP(I, w1, b1)\n","\n","  # layer 2 forward pass\n","\n","  P = SLP(A1, w2, b2)\n","\n","  # weight bias recomputation\n","\n","  w1, b1, w2, b2, mse = back_prop(I, Y, P, A1, w1, w2, b1, b2, lr)\n","\n","  # printing of epoch results\n","\n","  print(\"\\nActivation matrix:\\n\")\n","  print(P)\n","\n","  print(\"\\nGround truth matrix:\\n\")\n","  print(Y)\n","\n","  print(f\"\\nMean squared error: {mse}\")\n","\n","# ========================= final results of trained model\n","\n","print(\"\\nPrediction matrix:\\n\")\n","print(P)\n","\n","print(\"\\nGround truth matrix:\\n\")\n","print(Y)"]},{"cell_type":"markdown","source":["# IMPLEMENTATION - trial 2"],"metadata":{"id":"uUfk8HPYztnL"}},{"cell_type":"code","source":["from IPython.core.splitinput import split_user_input\n","# import required libraries\n","\n","import numpy as np\n","\n","# input matrix - I\n","\n","I = np.array([\n","    [0, 0],\n","    [0, 1],\n","    [1, 0],\n","    [1, 1]\n","  ])\n","\n","# ground truth matrix - Y\n","\n","Y = np.array([\n","    [0],\n","    [1],\n","    [1],\n","    [0]\n","])\n","\n","# defining hyper parameters\n","\n","epoch = 1200\n","\n","lr = 1.5\n","\n","# initiating weight & bias matrices\n","\n","w1 = np.random.randn(2, 2)\n","b1 = np.random.randn(1, 2)\n","\n","w2 = np.random.randn(2, 1)\n","b2 = np.random.randn(1, 1)\n","\n","# user defined function\n","\n","def sigmoid(x):\n","  return 1 / (1 + np.exp(-x))\n","\n","def sigmoid_derivative(x):\n","  return sigmoid(x) * (1 - sigmoid(x))\n","\n","def SLP(I, w, b):\n","  return sigmoid(np.dot(I, w) + b)\n","\n","def back_prop(I, Y, P, w1, b1, w2, b2, A1, lr):\n","\n","  # calculating mse\n","\n","  mse = np.mean((P - Y) ** 2)\n","\n","  # calculating error gradients\n","\n","  delta2 = (2 / I.shape[0]) * (P - Y) * sigmoid_derivative(np.dot(A1, w2) + b2)\n","\n","  delta1 = np.dot(delta2, w2.T) * sigmoid_derivative(np.dot(I, w1) + b1)\n","\n","  # calculation of weight and bias gradients\n","\n","  dw1 = np.dot(I.T, delta1)\n","  dw2 = np.dot(A1.T, delta2)\n","\n","  db1 = np.sum(delta1, axis=0)\n","  db2 = np.sum(delta2, axis=0)\n","\n","  # returning new weights and bias\n","\n","  return (w1 - dw1), (b1 - db1), (w2 - dw2), (b2 - db2), mse\n","\n","# training of the AI model\n","\n","print(\"\\nBeginning model training!\\n\")\n","\n","for i in range(epoch):\n","  print(f\"\\nEpoch {i+1}:\\n\")\n","\n","  # layer 1 forward pass\n","\n","  A1 = SLP(I, w1, b1)\n","\n","  # layer 2 forward pass\n","\n","  P = SLP(A1, w2, b2)\n","\n","  # back propagation & error calculation\n","\n","  w1, b1, w2, b2, mse = back_prop(I, Y, P, w1, b1, w2, b2, A1, lr)\n","\n","  # printing the results of each epoch\n","\n","  print(\"\\nPrediction matrix:\\n\")\n","  print(P)\n","\n","  print(\"\\nGround truth matrix:\\n\")\n","  print(Y)\n","\n","  print(f\"MSE: {mse}\")\n","\n","# printing final model results\n","\n","print(\"\\nModel training completed!\")\n","\n","print(\"\\nModel prediction:\\n\")\n","print(P)\n","\n","print(\"\\nGround truth matrix:\\n\")\n","print(Y)"],"metadata":{"id":"gmSNrntombwI","executionInfo":{"status":"ok","timestamp":1781775208758,"user_tz":-330,"elapsed":733,"user":{"displayName":"bbr2007","userId":"03194248298110772959"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"1d847390-2137-49f6-c9a8-54b3d715209f"},"execution_count":23,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1;30;43mStreaming output truncated to the last 5000 lines.\u001b[0m\n","\n","\n","Prediction matrix:\n","\n","[[0.